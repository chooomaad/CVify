<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>

	<key>CFBundleDisplayName</key>
	<string>CVify</string>

	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>

	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>

	<key>CFBundleName</key>
	<string>CVify</string>

	<key>CFBundlePackageType</key>
	<string>APPL</string>

	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>

	<key>CFBundleSignature</key>
	<string>????</string>

	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>

	<!-- URL Scheme pour Supabase deep links (email confirmation, reset password) -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>io.cvify.app</string>
			</array>
		</dict>
	</array>

	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- Écran de lancement -->
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>

	<key>UIMainStoryboardFile</key>
	<string>Main</string>

	<!-- Orientation portrait uniquement (iPhone) -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>

	<!-- iPad : toutes les orientations requises par Apple pour le multitâche.
	     UIRequiresFullScreen désactive le Split View / Slide Over et
	     permet de rester en portrait sans déclencher l'erreur 90474. -->
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<key>UIRequiresFullScreen</key>
	<true/>

	<!-- Permissions photo & caméra -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>CVify accède à votre galerie pour ajouter votre photo de profil et votre photo de CV.</string>

	<key>NSCameraUsageDescription</key>
	<string>CVify utilise l'appareil photo pour prendre votre photo de profil.</string>

	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>CVify sauvegarde des photos dans votre galerie.</string>

	<!-- Réseau local — requis quand NSBonjourServices est déclaré (Flutter debug/profile) -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>CVify utilise le réseau local pour les outils de développement Flutter.</string>

	<key>NSBonjourServices</key>
	<array>
		<string>_dartobservatory._tcp</string>
	</array>

	<!-- Performance iOS -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>

	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- App Store : pas de chiffrement supplémentaire -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
