platform :ios, '13.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'

      # Explicit Swift 5.0 — avoids ABI mismatch between pod Swift modules
      # compiled with different toolchains on CI (Codemagic Xcode 15/16).
      config.build_settings['SWIFT_VERSION'] = '5.0'
    end

    # ── Privacy Manifest bundle fix (Xcode 15+ / CocoaPods) ──────────────────
    #
    # CocoaPods generates *_privacy targets for pods that ship PrivacyInfo.xcprivacy:
    #   sqflite_darwin_privacy, url_launcher_ios_privacy,
    #   shared_preferences_foundation_privacy, path_provider_foundation_privacy, …
    #
    # These targets are pure resource bundles (no Swift/ObjC source).
    # CocoaPods generates them with product_type = com.apple.product-type.bundle,
    # which Xcode 15 treats as a loadable bundle — meaning it expects a Mach-O
    # binary at sqflite_darwin_privacy.bundle/sqflite_darwin_privacy.
    # Because there are no source files, the binary never gets linked, and
    # the Archive phase fails with "Build input file cannot be found".
    #
    # Fix: For every *_privacy target, force MACH_O_TYPE to empty string.
    # An empty MACH_O_TYPE on a .bundle target tells the linker to create a
    # resource-only wrapper with NO executable inside — which is correct for
    # a bundle containing only PrivacyInfo.xcprivacy.
    # CODE_SIGNING_ALLOWED/REQUIRED/IDENTITY are cleared for the same reason:
    # resource-only bundles have nothing to sign.
    if target.name.end_with?('_privacy')
      target.build_configurations.each do |config|
        config.build_settings['MACH_O_TYPE']             = ''
        config.build_settings['CODE_SIGNING_ALLOWED']    = 'NO'
        config.build_settings['CODE_SIGNING_REQUIRED']   = 'NO'
        config.build_settings['CODE_SIGN_IDENTITY']      = ''
        config.build_settings['SKIP_INSTALL']            = 'NO'
      end
    end
    # ─────────────────────────────────────────────────────────────────────────

    # Guarantees Swift runtime is embedded in Release archives for all
    # non-bundle pod targets (PathProviderPlugin, SharedPreferencesPlugin,
    # image_picker_ios, url_launcher_ios, etc.).
    unless target.name.end_with?('_privacy')
      target.build_configurations.each do |config|
        config.build_settings['ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES'] = 'YES'
      end
    end

    # Disable arm64 for simulator — avoids "building for iOS Simulator,
    # but linking in object file built for iOS" on Apple Silicon Macs.
    target.build_configurations.each do |config|
      if config.name == 'Debug' || config.name == 'Profile'
        config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64'
      end
    end
  end
end
